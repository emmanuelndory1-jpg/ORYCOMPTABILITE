rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Helpers
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check - uses get() so must be used sparingly (not in list)
    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == "emmanuelndory1@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // ===============================================================
    // Entity Validators (The "Anti-Update-Gap")
    // ===============================================================

    function isValidRequisition(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.description is string && data.description.size() <= 1000 &&
        data.amount is number &&
        data.status in ["draft", "pending", "approved_mgr", "approved_fin", "approved", "rejected", "ordered"] &&
        data.date is string &&
        (data.institutionType == null || data.institutionType in ["Ministère", "Institution Publique", "Collectivité Locale", "Entreprise Publique", "Autre"]) &&
        (data.institutionName == null || (data.institutionName is string && data.institutionName.size() <= 200)) &&
        (data.budgetLine == null || (data.budgetLine is string && data.budgetLine.size() <= 100)) &&
        (data.projectCode == null || (data.projectCode is string && data.projectCode.size() <= 100)) &&
        (data.items == null || (data.items is list && data.items.size() <= 50)) &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    function isValidRFQ(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.requisitionId is string &&
        data.status in ["sent", "received", "closed"] &&
        data.date is string &&
        (data.supplier_ids == null || (data.supplier_ids is list && data.supplier_ids.size() <= 20)) &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    function isValidPurchaseOrder(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.requisitionId is string &&
        data.supplier_name is string && data.supplier_name.size() <= 200 &&
        data.amount is number &&
        data.status in ["draft", "sent", "partially_received", "received", "cancelled"] &&
        data.date is string &&
        data.expected_delivery is string &&
        (data.items == null || (data.items is list && data.items.size() <= 50)) &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    function isValidGoodsReceipt(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.poId is string &&
        data.po_reference is string &&
        data.supplier_name is string &&
        data.status in ["received", "pending_inspection"] &&
        data.date is string &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    function isValidInvoiceMatching(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.po_reference is string &&
        data.receipt_reference is string &&
        data.supplier_name is string &&
        data.amount_invoice is number &&
        data.status in ["matched", "discrepancy", "pending", "accounted"] &&
        data.date is string &&
        (data.discrepancies == null || data.discrepancies is list) &&
        (data.anomalies == null || data.anomalies is list) &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
        data.reference is string && data.reference.size() <= 64 &&
        data.invoice_reference is string &&
        data.amount is number &&
        data.payment_date is string &&
        data.status in ["scheduled", "paid", "cancelled"] &&
        (data.priority_score == null || (data.priority_score is number && data.priority_score >= 1 && data.priority_score <= 10)) &&
        (data.attachments == null || (data.attachments is list && data.attachments.size() <= 10)) &&
        data.createdAt is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /p2p_requisitions/{reqId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidRequisition(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidRequisition(incoming()) && (
        // Identity integrity
        incoming().userId == existing().userId &&
        incoming().reference == existing().reference &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /p2p_rfqs/{rfqId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidRFQ(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidRFQ(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /p2p_purchase_orders/{poId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidPurchaseOrder(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidPurchaseOrder(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /p2p_goods_receipts/{receiptId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidGoodsReceipt(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidGoodsReceipt(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /p2p_invoice_matching/{matchId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidInvoiceMatching(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidInvoiceMatching(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /p2p_payments/{paymentId} {
      allow get: if isVerified() && (isOwner(existing().userId) || isAdmin());
      allow list: if isVerified() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidPayment(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidPayment(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().uid == userId && incoming().role in ['user', 'accountant'];
      allow update: if isOwner(userId) && incoming().uid == existing().uid && (incoming().role == existing().role || isAdmin());
    }

    match /companies/{companyId}/settings {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /ocr_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isVerified() && incoming().userId == request.auth.uid;
    }
  }
}
