# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# Database path (optional, defaults to compta.db)
DB_PATH="data/compta.db"

# Upload directory (optional, defaults to uploads/)
UPLOAD_DIR="uploads"

# JWT Secret (optional but recommended for production)
JWT_SECRET="your-secret-key"

# Mobile Money Aggregator API (e.g., FedaPay, CinetPay for Orange Money, MTN, Wave)
MOBILE_MONEY_API_KEY="your-api-key"
MOBILE_MONEY_API_SECRET="your-api-secret"
MOBILE_MONEY_WEBHOOK_SECRET="your-webhook-secret"
MOBILE_MONEY_ENV="sandbox" # sandbox or production
